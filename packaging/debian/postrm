#!/bin/sh
set -e

# Only clean up files if the system is explicitly removing data entirely
if [ "$1" = "purge" ]; then
    echo "Purging xzpv system configuration data..."

    # Check if the global file exists and remove it
    if [ -f /etc/xzpv/xzpv.conf ]; then
        rm -f /etc/xzpv/xzpv.conf
    fi

    # Remove the workspace directory if it is completely empty
    if [ -d /etc/xzpv ]; then
        rmdir /etc/xzpv --ignore-fail-on-non-empty
    fi
fi

exit 0